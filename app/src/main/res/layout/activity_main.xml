<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="夜晚降亮 · 护眼蒙版"
            android:textColor="@color/accent" />

        <!-- 权限状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="权限状态"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_overlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="悬浮窗：—"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_status_notif"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="通知：—"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="启动蒙版"
            android:textColor="@color/btn_text" />

        <Button
            android:id="@+id/btn_perm_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="悬浮窗权限"
            android:textColor="@color/btn_text" />

        <!-- 设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="蒙版设置"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="透明度（5%–95%）"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <SeekBar
                    android:id="@+id/seek_opacity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="90" />

                <TextView
                    android:id="@+id/tv_opacity_val"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="60%"
                    android:textColor="@color/accent"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="颜色预设"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="点按=应用并选中 · 长按=存入当前颜色"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/ll_presets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="自定义颜色（H / S / L）"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="H  色相" android:textColor="@color/text_secondary" />
            <SeekBar android:id="@+id/seek_h" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:max="360" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="S  饱和度" android:textColor="@color/text_secondary" />
            <SeekBar android:id="@+id/seek_s" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:max="100" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="L  亮度" android:textColor="@color/text_secondary" />
            <SeekBar android:id="@+id/seek_l" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:max="100" />

            <Button
                android:id="@+id/btn_save_slot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="保存颜色预设"
                android:textColor="@color/btn_text" />

            <Switch
                android:id="@+id/sw_hidefab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="隐藏悬浮按钮"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="悬浮按钮：点按=打开控制面板，长按=启用/关闭蒙版，拖动可自由悬停（靠近边缘自动收边）。"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_exit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#B00020"
            android:text="退出程序"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</ScrollView>
